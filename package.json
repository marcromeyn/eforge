{
  "name": "eforge",
  "version": "0.1.0",
  "description": "Autonomous plan-build-review CLI for code generation",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "eforge": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup && pnpm --filter monitor-ui build",
    "build:ui": "pnpm --filter monitor-ui build",
    "dev": "tsx src/cli.ts",
    "dev:trace": "node --env-file=.env node_modules/.bin/tsx src/cli.ts",
    "dev:mock": "tsx src/monitor/mock-server.ts",
    "dev:monitor": "pnpm --filter monitor-ui dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "agent",
    "code-generation",
    "claude"
  ],
  "author": "Schaake Solutions LLC",
  "packageManager": "pnpm@10.26.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.76",
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "langfuse": "^3.38.6",
    "ora": "^8.2.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
