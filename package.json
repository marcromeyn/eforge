{
  "name": "eforge",
  "version": "0.1.10",
  "description": "Autonomous plan-build-review CLI for code generation",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types/engine/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/types/engine/index.d.ts",
  "bin": {
    "eforge": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eforge-build/eforge.git"
  },
  "homepage": "https://eforge.build",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && node --import tsx ./scripts/post-build.ts && pnpm --filter monitor-ui build && tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm build && pnpm test",
    "build:ui": "pnpm --filter monitor-ui build",
    "dev": "tsx src/cli.ts",
    "dev:trace": "node --env-file=.env node_modules/.bin/tsx src/cli.ts",
    "dev:mock": "tsx src/monitor/mock-server.ts",
    "dev:monitor": "pnpm --filter monitor-ui dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "agent",
    "code-generation",
    "claude"
  ],
  "author": "Schaake Solutions LLC",
  "packageManager": "pnpm@10.26.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.84",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "langfuse": "^3.38.6",
    "ora": "^8.2.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
